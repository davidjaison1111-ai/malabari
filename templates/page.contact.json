          "type": "collapsible_row",
          "settings": {
            "heading": "Shipping & Delivery",
            "row_content": "<p>We ship worldwide with care. Domestic orders within India are delivered in 3-5 business days. International shipping takes 7-14 business days depending on location.</p><p><a href=\"/pages/shipping-policy\">View shipping policy →</a></p>",
            "icon": "truck"
          }
        },
