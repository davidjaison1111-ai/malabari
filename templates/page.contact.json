          "type": "collapsible_row",
          "settings": {
            "heading": "Returns & Refunds",
            "row_content": "<p>Not satisfied with your purchase? We offer hassle-free returns within 30 days of delivery. Your satisfaction is our priority.</p><p><a href=\"/pages/refund-policy\">View return policy →</a></p>",
            "icon": "return"
          }
        },
