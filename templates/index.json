        "story_heading": {
          "type": "heading",
          "settings": {
            "heading": "Rooted in a Sunday Market",
            "heading_size": "h1"
          }
        },
        "story_text": {
          "type": "text",
          "settings": {
            "text": "<p>While travelling rural India, our founder David wandered into a farmers' Sunday market in Upputhara, Idukki — and watched generations of craft go home unsold. He stayed, listened, and in 2022 built MalabarRoots with his father: a direct bridge between 36 Kerala farmers and kitchens that value the real thing. Every jar and pack you buy sends fair value straight back to the soil it came from.</p>",
            "text_style": "body"
          }
        },
        "story_button": {
          "type": "button",
          "settings": {
            "button_label": "Read Our Full Story",
            "button_link": "shopify://pages/about-us",
            "button_style_secondary": true
          }
        }
      },
