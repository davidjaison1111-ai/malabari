          {%- if section.settings.review_4_tag != blank -%}
            <span class="footer-review-tag">{{ section.settings.review_4_tag }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if review_5 != blank -%}
        <div class="footer-review-card">
          <div class="footer-review-stars">★★★★★</div>
          <p class="footer-review-text">{{ review_5 }}</p>
          <div class="footer-review-author">
            <div class="footer-review-avatar">{{ section.settings.review_5_name | slice: 0 }}</div>
