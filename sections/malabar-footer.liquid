{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer-malabar {
    background: var(--color-background);
    color: var(--color-text);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: 60px;
  }

  .footer-reviews-section {
    background: linear-gradient(135deg, rgba(var(--color-foreground), 0.03) 0%, rgba(var(--color-foreground), 0.06) 100%);
    padding: 60px 0;
  }

  .footer-reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .footer-review-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .footer-review-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .footer-review-stars {
    color: #FFB800;
    font-size: 18px;
    margin-bottom: 12px;
    letter-spacing: 2px;
  }

  .footer-review-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 16px;
    font-style: italic;
  }

  .footer-review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 16px;
  }

  .footer-review-info h4 {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
  }

  .footer-review-info p {
    font-size: 12px;
    color: rgba(var(--color-foreground), 0.6);
    margin: 2px 0 0 0;
  }

  .footer-review-tag {
    display: inline-block;
    background: rgba(var(--color-foreground), 0.08);
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
    margin-top: 8px;
    color: var(--color-text);
  }

  .footer-reviews-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 50px;
    padding: 0 20px;
  }

  .footer-reviews-header h2 {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--color-text);
  }

  .footer-reviews-header p {
    font-size: 16px;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .footer-overall-rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 20px;
  }

  .footer-rating-big {
    font-size: 48px;
    font-weight: 700;
    color: var(--color-text);
  }

  .footer-rating-stars {
    color: #FFB800;
    font-size: 24px;
  }

  .footer-rating-count {
    font-size: 14px;
    color: rgba(var(--color-foreground), 0.6);
  }

  .footer-main-section {
    padding: 70px 0 50px;
  }

  .footer-main-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 40px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .footer-brand-column h3 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 16px;
    color: var(--color-text);
  }

  .footer-brand-column p {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0 0 20px;
  }

  .footer-social-links {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .footer-social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .footer-social-link:hover {
    background: var(--color-text);
    color: var(--color-background);
    transform: translateY(-2px);
  }

  .footer-column h4 {
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 20px;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column li {
    margin-bottom: 12px;
  }

  .footer-column a {
    color: rgba(var(--color-foreground), 0.7);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .footer-column a:hover {
    color: var(--color-text);
  }

  .footer-newsletter-column {
    background: linear-gradient(135deg, rgba(var(--color-foreground), 0.05) 0%, rgba(var(--color-foreground), 0.08) 100%);
    padding: 30px;
    border-radius: 16px;
  }

  .footer-newsletter-column h4 {
    font-size: 18px;
    margin: 0 0 10px;
  }

  .footer-newsletter-column p {
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0 0 20px;
    line-height: 1.6;
  }

  .footer-newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-newsletter-input {
    padding: 14px 18px;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 8px;
    font-size: 14px;
    background: white;
    color: var(--color-text);
    transition: border-color 0.3s ease;
  }

  .footer-newsletter-input:focus {
    outline: none;
    border-color: var(--color-text);
  }

  .footer-newsletter-button {
    padding: 14px 24px;
    background: var(--color-text);
    color: var(--color-background);
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-newsletter-button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .footer-newsletter-note {
    font-size: 11px;
    color: rgba(var(--color-foreground), 0.5);
    margin-top: 12px;
    text-align: center;
  }

  .footer-bottom {
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    padding: 30px 0;
    margin-top: 40px;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .footer-copyright {
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.6);
  }

  .footer-copyright a {
    color: rgba(var(--color-foreground), 0.7);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-copyright a:hover {
    text-decoration: underline;
  }

  .footer-policies {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-policies a {
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.6);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-policies a:hover {
    color: var(--color-text);
  }

  @media screen and (max-width: 1024px) {
    .footer-main-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .footer-brand-column {
      grid-column: span 2;
    }
  }

  @media screen and (max-width: 768px) {
    .footer-reviews-section {
      padding: 40px 0;
    }

    .footer-reviews-header h2 {
      font-size: 22px;
    }

    .footer-rating-big {
      font-size: 36px;
    }

    .footer-main-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .footer-brand-column {
      grid-column: span 1;
    }

    .footer-newsletter-column {
      order: -1;
    }

    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }

    .footer-policies {
      justify-content: center;
    }
  }

  @media screen and (max-width: 480px) {
    .footer-reviews-grid {
      grid-template-columns: 1fr;
    }

    .footer-review-card {
      padding: 20px;
    }

    .footer-overall-rating {
      flex-direction: column;
      gap: 8px;
    }
  }
{%- endstyle -%}

<footer class="footer-malabar">
  <!-- Reviews Section -->
