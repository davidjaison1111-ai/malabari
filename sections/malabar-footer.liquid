      <!-- Shop Column -->
      <div class="footer-column">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/all">All Spices</a></li>
          <li><a href="/collections/cardamom">Cardamom</a></li>
          <li><a href="/collections/pepper">Black Pepper</a></li>
          <li><a href="/collections/cinnamon">Cinnamon</a></li>
          <li><a href="/collections/cloves">Cloves</a></li>
          <li><a href="/collections/nutmeg">Nutmeg & Mace</a></li>
          <li><a href="/collections/turmeric">Turmeric</a></li>
          <li><a href="/collections/spice-blends">Spice Blends</a></li>
          <li><a href="/collections/gift-boxes">Gift Boxes</a></li>
        </ul>
      </div>

      <!-- About Column -->
      <div class="footer-column">
        <h4>About</h4>
        <ul>
          <li><a href="/pages/our-story">Our Story</a></li>
          <li><a href="/pages/sourcing">Sourcing</a></li>
          <li><a href="/pages/sustainability">Sustainability</a></li>
          <li><a href="/pages/farmers">Our Farmers</a></li>
          <li><a href="/pages/quality">Quality Promise</a></li>
          <li><a href="/blogs/journal">Journal</a></li>
          <li><a href="/pages/recipes">Recipes</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>
      </div>

      <!-- Newsletter Column -->
      <div class="footer-newsletter-column">
        <h4>Weekly Spice Inspiration</h4>
        <p>Join 50,000+ spice enthusiasts. Every Thursday: one recipe, two cooking tips, and exclusive offers. No spam — ever.</p>
        
        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer-newsletter-form">
            <input
              type="email"
              name="contact[email]"
              class="footer-newsletter-input"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              placeholder="Your email address"
              required
            >
            <button type="submit" class="footer-newsletter-button" name="commit" id="Subscribe">
              Subscribe Free
            </button>
          </div>
          <p class="footer-newsletter-note">Your data is safe. Unsubscribe with one click, anytime.</p>
        {%- endform -%}
      </div>
    </div>
  </section>

  <!-- Bottom Section -->
  <div class="footer-bottom">
    <div class="footer-bottom-content">
      <div class="footer-copyright">
        <small>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}. All rights reserved.</small>
      </div>
      
      <div class="footer-policies">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <a href="{{ policy.url }}">{{ policy.title }}</a>
          {%- endif -%}
        {%- endfor -%}
