      {%- endif -%}

      {%- if review_4 != blank -%}
        <div class="footer-review-card">
          <div class="footer-review-stars">★★★★★</div>
          <p class="footer-review-text">{{ review_4 }}</p>
          <div class="footer-review-author">
            <div class="footer-review-avatar">{{ section.settings.review_4_name | slice: 0 }}</div>
