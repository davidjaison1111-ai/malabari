        <div class="footer-review-card">
          <div class="footer-review-stars">★★★★★</div>
          <p class="footer-review-text">{{ review_6 }}</p>
          <div class="footer-review-author">
            <div class="footer-review-avatar">{{ section.settings.review_6_name | slice: 0 }}</div>
